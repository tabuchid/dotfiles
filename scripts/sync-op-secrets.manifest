# Format: ENV_VAR|op://vault/item/field|account
# Account is optional; default is my.1password.com

JIRA_EMAIL|op://Private/Jira API Token/email|my.1password.com
JIRA_API_TOKEN|op://Private/Jira API Token/credential|my.1password.com
JIRA_DOMAIN|op://Private/Jira API Token/domain|my.1password.com
GITHUB_PACKAGES_TOKEN|op://Private/GitHub Packages Token/credential|my.1password.com
SENTRY_AUTH_TOKEN|op://Private/Sentry Auth Token/credential|my.1password.com
SENTRY_ORG|op://Private/Sentry Auth Token/org|my.1password.com
